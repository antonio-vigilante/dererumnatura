---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['fregio', className]}>
  <svg class="fregio-atomo" viewBox="0 0 24 24" width="1.3em" height="1.3em" aria-hidden="true" focusable="false">
    <circle cx="12" cy="12" r="1.6" fill="currentColor" />
    <ellipse cx="12" cy="12" rx="10" ry="4.2" />
    <ellipse cx="12" cy="12" rx="10" ry="4.2" transform="rotate(60 12 12)" />
    <ellipse cx="12" cy="12" rx="10" ry="4.2" transform="rotate(120 12 12)" />
  </svg>
</div>

<style>
  .fregio-atomo ellipse {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.1;
  }
</style>
