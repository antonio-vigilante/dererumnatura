---
const anno = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="sito no-stampa">
  <div class="contenitore">
    
    <p class="colophon tenue">
     Licenza Creative Commons BY-SA 4.0. Ultimo aggiornamento: luglio 2026.
  </div>
</footer>

<style>
  footer.sito {
    border-top: 2px solid var(--linea);
    margin-top: 4rem;
    padding: 2.5rem 0 3rem;
    text-align: center;
  }
  .motto {
    font-style: italic;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }
  .colophon {
    font-size: 0.85rem;
    max-width: 40rem;
    margin-inline: auto;
  }
  .link-guida {
    color: var(--oro);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .link-guida:hover { color: var(--rubrica); }
</style>
