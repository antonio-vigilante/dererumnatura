---
const base = import.meta.env.BASE_URL;
---

<header class="sito no-stampa">
  <div class="contenitore barra">
    <a class="marca" href={base}>
      <span class="marca-titolo">De Rerum Natura</span>
    </a>

    <button class="hamburger" id="hamburger"
      aria-label="Apri il menu" aria-expanded="false" aria-controls="menu-sito">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <p class="segnaposto tenue">
      <em>Ita res accendent lumina rebus</em><br>
      così ogni cosa accenderà ogni altra. (I, 1117)
    </p>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('hamburger');
    if (!btn) return;

    btn.addEventListener('click', function () {
      const aperto = document.documentElement.classList.toggle('menu-aperto');
      btn.setAttribute('aria-expanded', String(aperto));
    });
  })();
</script>

<style>
  header.sito {
    border-bottom: 2px solid var(--linea);
    background: color-mix(in srgb, var(--carta) 92%, transparent);
    backdrop-filter: blur(6px);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .barra {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.7rem 0;
  }

  .marca {
    display: flex;
    text-decoration: none;
    flex-shrink: 0;
  }
  .marca-titolo {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--rubrica);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Hamburger: nascosto su desktop, mostrato quando la sidebar collassa. */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    padding: 0.35rem 0.4rem;
    background: transparent;
    border: 1.5px solid var(--linea);
    border-radius: 4px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .hamburger span {
    display: block;
    height: 2px;
    background: var(--inchiostro);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .hamburger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .hamburger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .segnaposto {
    flex: 1;
    min-width: 0;
    max-width: 24rem;
    margin-left: auto;
    font-size: 0.72rem;
    line-height: 1.35;
    text-align: right;
    color: var(--inchiostro-tenue);
  }

  @media (max-width: 800px) {
    .hamburger { display: flex; margin-left: auto; }
    .segnaposto { display: none; }
  }
</style>
