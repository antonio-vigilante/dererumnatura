---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Fregio from '../components/Fregio.astro';
import IndicePagina from '../components/IndicePagina.astro';

const passi = (await getCollection('passi', ({ data }) => !data.bozza)).sort(
  (a, b) => a.data.ordine - b.data.ordine
);
const base = import.meta.env.BASE_URL;

// Raggruppa per libro.
const libri = ['I', 'II', 'III', 'IV', 'V', 'VI'];
const titoliLibri = [
  'La materia e il vuoto',
  'Il moto e le forme degli atomi',
  "L'anima e la morte",
  'La conoscenza e i simulacri',
  'Il mondo e la civiltà',
  'I fenomeni celesti e la peste',
];
const perLibro = new Map<number, typeof passi>();
for (const p of passi) {
  const arr = perLibro.get(p.data.libro) ?? [];
  arr.push(p);
  perLibro.set(p.data.libro, arr);
}
---

<BaseLayout titolo="Il poema">
  <div class="contenitore layout-menu">
    <Sidebar>
      <IndicePagina selettore=".indice" livelli="h2" />
    </Sidebar>
    <div class="indice colonna-testo">
    <h1>Il poema</h1>

    <Fregio />

    {[...perLibro.entries()].map(([n, elenco]) => (
      <section class="libro" id={`libro-${n}`}>
        <h2 class="titolo-libro">
          <span class="num maiuscoletto">Libro {libri[n - 1]}</span>
                  </h2>
        <ol class="passi-libro">
          {elenco.map((p) => (
            <li>
              <a href={`${base}passi/${p.id}/`}>
                <span class="p-tit">{p.data.titolo}</span>
                <span class="p-versi tenue">vv. {p.data.versi}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))}
    </div>
  </div>
</BaseLayout>

<style>
  h1 { text-align: center; }
  .introd { text-align: center; font-size: 1.05rem; }

  .libro { scroll-margin-top: 5rem; }
  .titolo-libro {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    border-bottom: 2px solid var(--linea);
    padding-bottom: 0.4rem;
  }
  .num { color: var(--rubrica); font-size: 1.5rem; }
  .etichetta-libro { font-style: italic; font-size: 1.05rem; }

  .passi-libro { list-style: none; padding: 0; margin: 0.8rem 0 2rem; }
  .passi-libro li { margin: 0; }
  .passi-libro a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    padding: 0.5rem 0.3rem;
    border-bottom: 1px dotted var(--linea);
  }
  .passi-libro a:hover { background: var(--evidenzia); }
  .p-tit { font-size: 1.2rem; color: var(--rubrica); }
  .p-versi { font-size: 0.85rem; white-space: nowrap; }
</style>
