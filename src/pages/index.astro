---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Fregio from '../components/Fregio.astro';

const passi = (await getCollection('passi', ({ data }) => !data.bozza)).sort(
  (a, b) => a.data.ordine - b.data.ordine
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout titolo="Frontespizio" descrizione="Un'edizione digitale ad accesso aperto del De rerum natura di Lucrezio.">
  <div class="contenitore layout-menu">

    <Sidebar />

    {/* ---- Corpo della homepage ---- */}
    <article class="corpo">

      <header class="testata-home">
        <p class="epigrafe maiuscoletto tenue">Tito Lucrezio Caro</p>
        <h1>De rerum natura</h1>
        <p class="sottotitolo">La natura delle cose</p>
       
      </header>

      <Fregio />


      {/* ================================================ PRESENTAZIONE */}
      <section id="presentazione">

        <figure class="immagine-apertura">
          <img src={`${base}immagini/arapacis.jpg`} alt="Rilievo dell'Ara Pacis raffigurante una figura femminile con due bambini, affiancata da personificazioni allegoriche" />
          <figcaption>Tellus Mater, rilievo dell'Ara Pacis, Roma. Foto di <a href="https://commons.wikimedia.org/wiki/File:AraPacisReliefTellusMater.JPG">Chris Nas</a>. Licenza Creative Commons BY-SA 4.0 International.
</figcaption>
        </figure>

        <p>

"Il <em>De rerum natura</em> di Lucrezio è la prima grande opera di poesia in cui la conoscenza del mondo diventa dissoluzione della compattezza del mondo, percezione di ciò che è infinitamente minuto e mobile e leggero", affermava Italo Calvino nelle <em>Lezioni americane</em>. Ed è da ricercare qui la ragione dell'attualità di un poema che a dire il vero, benché dimenticato per diversi secoli, non ha mai smesso di incontrare i lettori e inquietarli. Lucrezio vede un mondo che, sotto la luce implacabile della ragione, si fa evanescente, perde i confini consueti e si scioglie in una ridda di processi fisici che poco concedono al nostro bisogno di concolazione. Ed è in questo mondo – che ha non poche affinità con la Vacuità buddhista, ma fa pensare anche al Dao – che bisogna esercitarsi nell'arte di vivere in modo semplice e libero.</p>

<p>Intendo qui offrire una nuova traduzione di una delle opere più tradotte della letteratura latina. Una traduzione in endecasillabi, che si aggiunge a quelle già disponibili in verso libero e prosa, sul testo critico di Cyrill Bailey e con una Guida alla lettura.</p>

<p align="right">Antonio Vigilante</p>
            </section>
 

    </article>
  </div>
</BaseLayout>

<style>
  /* ---- Corpo ---- */
  .corpo { max-width: 52rem; }

  /* ---- Testata ---- */
  .testata-home { text-align: center; margin-bottom: 0; }
  .epigrafe { font-size: 0.95rem; letter-spacing: 0.15em; }
  .testata-home h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.3rem, 6.2vw, 3.9rem);
    font-weight: 500;
    text-transform: uppercase;
    margin: 0.4rem 0 0;
    color: var(--rubrica);
    letter-spacing: 0.03em;
  }
  .sottotitolo {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--inchiostro-tenue);
    margin-top: 0.3rem;
  }
  .entra {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    background: var(--rubrica);
    border: 1.5px solid var(--rubrica);
    padding: 0.6rem 1.8rem;
    border-radius: 4px;
    color: var(--carta);
    transition: all 0.2s ease;
  }
  .entra:hover { background: var(--rubrica-scura); border-color: var(--rubrica-scura); }

  /* ---- Immagine di apertura ---- */
  .immagine-apertura {
    margin: 0 0 2rem;
    text-align: center;
  }
  .immagine-apertura img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--linea);
  }
  .immagine-apertura figcaption {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    font-style: italic;
    color: var(--inchiostro-tenue);
  }

  section {
    margin-top: 3rem;
    scroll-margin-top: 5.5rem;
  }
  section h2 {
    border-bottom: 1px solid var(--linea);
    padding-bottom: 0.4rem;
    margin-bottom: 1.2rem;
  }
</style>
